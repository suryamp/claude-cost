#!/usr/bin/env python3
"""Summarize Claude Code API usage and subscription value from local conversation files."""

import json
import glob
import os
import sys
from datetime import datetime, timezone
from collections import defaultdict

# Per-model pricing (USD per million tokens).
# Cache write ratios: 1.25× input (5-min TTL), 2× input (1-hr TTL).
# Cache read ratio:   0.1× input.
PRICING = {
    "claude-fable-5":    {"input": 10.00, "output": 50.00, "cache_write_5m": 12.50, "cache_write_1h": 20.00, "cache_read": 1.00},
    "claude-mythos-5":   {"input": 10.00, "output": 50.00, "cache_write_5m": 12.50, "cache_write_1h": 20.00, "cache_read": 1.00},
    "claude-opus-4-8":   {"input":  5.00, "output": 25.00, "cache_write_5m":  6.25, "cache_write_1h": 10.00, "cache_read": 0.50},
    "claude-opus-4-7":   {"input":  5.00, "output": 25.00, "cache_write_5m":  6.25, "cache_write_1h": 10.00, "cache_read": 0.50},
    "claude-opus-4-6":   {"input":  5.00, "output": 25.00, "cache_write_5m":  6.25, "cache_write_1h": 10.00, "cache_read": 0.50},
    "claude-sonnet-4-6": {"input":  3.00, "output": 15.00, "cache_write_5m":  3.75, "cache_write_1h":  6.00, "cache_read": 0.30},
    "claude-haiku-4-5":  {"input":  1.00, "output":  5.00, "cache_write_5m":  1.25, "cache_write_1h":  2.00, "cache_read": 0.10},
    # Legacy / older models (approximate)
    "claude-opus-4-5":   {"input":  3.00, "output": 15.00, "cache_write_5m":  3.75, "cache_write_1h":  6.00, "cache_read": 0.30},
    "claude-sonnet-4-5": {"input":  3.00, "output": 15.00, "cache_write_5m":  3.75, "cache_write_1h":  6.00, "cache_read": 0.30},
}

# Fallback when the model isn't in the table above.
_DEFAULT_PRICING = PRICING["claude-sonnet-4-6"]

RESET = "\033[0m"
BOLD  = "\033[1m"
DIM   = "\033[2m"
GREEN = "\033[32m"
CYAN  = "\033[36m"
YELLOW= "\033[33m"


def get_pricing(model_id):
    if not model_id:
        return _DEFAULT_PRICING
    if model_id in PRICING:
        return PRICING[model_id]
    # Prefix match for dated snapshots (e.g., "claude-sonnet-4-6-20251114")
    for key in PRICING:
        if model_id.startswith(key):
            return PRICING[key]
    return _DEFAULT_PRICING


def load_config():
    path = os.path.expanduser("~/.config/claude-cost/config.json")
    try:
        with open(path) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return {}


def project_label(dir_name):
    parts = dir_name.split("-")
    try:
        idx = parts.index("suryamp")
        rest = "-".join(parts[idx + 1:])
        for prefix in ("dev-", "Downloads-"):
            if rest.startswith(prefix):
                rest = rest[len(prefix):]
        if "--claude-worktrees-" in rest:
            rest = rest.split("--")[0]
        return rest
    except ValueError:
        return dir_name


def parse_sessions(projects_dir, since=None):
    sessions = {}

    for proj_dir in sorted(glob.glob(projects_dir + "/*")):
        if not os.path.isdir(proj_dir):
            continue
        label = project_label(os.path.basename(proj_dir))

        for jsonl_path in glob.glob(proj_dir + "/*.jsonl"):
            sid = os.path.basename(jsonl_path).replace(".jsonl", "")
            s = {
                "project": label,
                # token totals (for display)
                "input": 0, "output": 0,
                "cache_write_5m": 0, "cache_write_1h": 0, "cache_read": 0,
                # dollar costs per type (computed per-message with model pricing)
                "input_cost": 0.0, "output_cost": 0.0,
                "cache_write_cost": 0.0, "cache_read_cost": 0.0,
                "first_time": None, "last_time": None,
                "messages": 0,
            }

            try:
                for line in open(jsonl_path, errors="ignore"):
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        r = json.loads(line)
                    except json.JSONDecodeError:
                        continue

                    if r.get("type") == "assistant":
                        msg = r.get("message", {})
                        usage = msg.get("usage")
                        if usage:
                            model = msg.get("model", "")
                            p = get_pricing(model)

                            inp  = usage.get("input_tokens", 0)
                            out  = usage.get("output_tokens", 0)
                            cr   = usage.get("cache_read_input_tokens", 0)
                            cc   = usage.get("cache_creation", {})
                            cw5  = cc.get("ephemeral_5m_input_tokens", 0)
                            cw1h = cc.get("ephemeral_1h_input_tokens", 0)

                            s["input"]         += inp
                            s["output"]        += out
                            s["cache_read"]    += cr
                            s["cache_write_5m"] += cw5
                            s["cache_write_1h"] += cw1h

                            s["input_cost"]       += inp  / 1e6 * p["input"]
                            s["output_cost"]      += out  / 1e6 * p["output"]
                            s["cache_write_cost"] += cw5  / 1e6 * p["cache_write_5m"]
                            s["cache_write_cost"] += cw1h / 1e6 * p["cache_write_1h"]
                            s["cache_read_cost"]  += cr   / 1e6 * p["cache_read"]
                            s["messages"] += 1

                    if r.get("type") in ("user", "assistant"):
                        ts = r.get("message", {}).get("timestamp") or r.get("timestamp")
                        if ts and isinstance(ts, str):
                            try:
                                dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
                                if s["first_time"] is None or dt < s["first_time"]:
                                    s["first_time"] = dt
                                if s["last_time"] is None or dt > s["last_time"]:
                                    s["last_time"] = dt
                            except ValueError:
                                pass
            except OSError:
                continue

            if s["messages"] == 0:
                continue
            if since and s["first_time"] and s["first_time"] < since:
                continue

            sessions[sid] = s

    return sessions


def session_cost(s):
    return s["input_cost"] + s["output_cost"] + s["cache_write_cost"] + s["cache_read_cost"]


def fmt_tokens(n):
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.0f}K"
    return str(n)


def bar(value, max_value, width=20):
    filled = int(round(value / max_value * width)) if max_value else 0
    filled = min(filled, width)
    return "█" * filled + "░" * (width - filled)


def fmt_rate(cost, tokens):
    if tokens == 0:
        return "  —    "
    return f"${cost / tokens * 1e6:>6.2f}/MTok"


def print_report(sessions, subscription, since_label="all time"):
    if not sessions:
        print("No conversations found.")
        return

    all_times = [s["first_time"] for s in sessions.values() if s["first_time"]]
    min_date = min(all_times).strftime("%Y-%m-%d") if all_times else "?"
    max_date = max(all_times).strftime("%Y-%m-%d") if all_times else "?"

    total_cost     = sum(session_cost(s) for s in sessions.values())
    total_input    = sum(s["input"]         for s in sessions.values())
    total_output   = sum(s["output"]        for s in sessions.values())
    total_cr       = sum(s["cache_read"]    for s in sessions.values())
    total_cw       = sum(s["cache_write_5m"] + s["cache_write_1h"] for s in sessions.values())
    total_in_cost  = sum(s["input_cost"]       for s in sessions.values())
    total_out_cost = sum(s["output_cost"]      for s in sessions.values())
    total_cw_cost  = sum(s["cache_write_cost"] for s in sessions.values())
    total_cr_cost  = sum(s["cache_read_cost"]  for s in sessions.values())

    roi = total_cost / subscription if subscription else 0

    print()
    print(f"{BOLD}Claude Code — Usage Report{RESET}  {DIM}({since_label}: {min_date} → {max_date}){RESET}")
    print("─" * 58)

    roi_color = GREEN if roi >= 1 else YELLOW
    print(f"  {'API value':20}  {roi_color}{BOLD}${total_cost:>8.2f}{RESET}")
    print(f"  {'Subscription':20}  ${subscription:>8.2f}/month")
    print(f"  {'ROI':20}  {roi_color}{BOLD}{roi:>8.1f}x{RESET}")
    print()

    print(f"{BOLD}  Token breakdown{RESET}")
    rows = [
        ("Output",       total_output, total_out_cost),
        ("Cache reads",  total_cr,     total_cr_cost),
        ("Cache writes", total_cw,     total_cw_cost),
        ("Input",        total_input,  total_in_cost),
    ]
    for label, tokens, cost in rows:
        rate_str = fmt_rate(cost, tokens)
        print(f"  {label:<14} {fmt_tokens(tokens):>6}  {rate_str}  = ${cost:>7.2f}")
    print()

    by_proj = defaultdict(lambda: {"sessions": 0, "cost": 0.0})
    for s in sessions.values():
        p = s["project"]
        by_proj[p]["sessions"] += 1
        by_proj[p]["cost"]     += session_cost(s)

    max_proj_cost = max(d["cost"] for d in by_proj.values()) if by_proj else 1

    print(f"{BOLD}  By project{RESET}")
    for proj, d in sorted(by_proj.items(), key=lambda x: -x[1]["cost"]):
        b = bar(d["cost"], max_proj_cost)
        print(f"  {proj:<22} {d['sessions']:>3}s  ${d['cost']:>7.2f}  {DIM}{b}{RESET}")
    print()

    top = sorted(sessions.items(), key=lambda x: session_cost(x[1]), reverse=True)[:8]
    print(f"{BOLD}  Top sessions by cost{RESET}")
    for sid, s in top:
        c = session_cost(s)
        date = s["first_time"].strftime("%Y-%m-%d") if s["first_time"] else "?"
        print(f"  ${c:>7.2f}  {date}  [{s['project']}]  {s['messages']} messages")
    print()
    print(f"{DIM}  Rates: per-model rack rates from Anthropic pricing.{RESET}")
    print(f"{DIM}  Config: ~/.config/claude-cost/config.json{RESET}")
    print()


def main():
    since = None
    since_label = "all time"

    args = sys.argv[1:]
    if args:
        arg = args[0]
        if arg in ("--month", "-m"):
            now = datetime.now(timezone.utc)
            since = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
            since_label = now.strftime("%B %Y")
        elif arg in ("--week", "-w"):
            from datetime import timedelta
            now = datetime.now(timezone.utc)
            since = now - timedelta(days=7)
            since_label = "last 7 days"
        elif arg in ("--help", "-h"):
            print("Usage: claude-cost [--month | --week]")
            print("  (no flag)   all tracked conversations")
            print("  --month/-m  current calendar month")
            print("  --week/-w   last 7 days")
            print()
            print("Config: ~/.config/claude-cost/config.json")
            print('  { "subscription": 100.00 }')
            return

    cfg = load_config()
    subscription = float(cfg.get("subscription", 100.00))

    projects_dir = os.path.expanduser("~/.claude/projects")
    sessions = parse_sessions(projects_dir, since=since)
    print_report(sessions, subscription, since_label=since_label)


if __name__ == "__main__":
    main()
